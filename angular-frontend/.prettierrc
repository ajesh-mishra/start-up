{
  "singleQuote": true,
  "printWidth": 120,
  "bracketSameLine": true,
  "trailingComma": "all",
  "arrowParens": "always",
  "endOfLine": "lf",
  "plugins": ["@xeonlink/prettier-plugin-organize-attributes"],
  "attributeSort": "ASC",
  "overrides": [
    {
      "files": "*.html",
      "options": {
        "parser": "angular"
      }
    }
  ]
}